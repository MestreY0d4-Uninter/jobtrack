{
  "name": "jobtrack-ads",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:deploy": "npm run db:deploy -w apps/api",
    "db:generate": "npm run db:generate -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "db:validate": "npm run db:validate -w apps/api"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
